{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/davidtranjs/zurek-marketplace/main/schema/manifest.schema.json",
  "title": "Zurek marketplace entry manifest",
  "type": "object",
  "required": ["id", "type", "name", "description", "author"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Unique kebab-case id. Must match the entry folder name."
    },
    "type": {
      "type": "string",
      "enum": ["mcp", "skill", "agent", "bundle"]
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1, "description": "One-line summary shown in the list." },
    "longDescription": { "type": "string", "description": "Optional markdown shown in the review pane." },
    "author": { "type": "string", "minLength": 1 },
    "homepage": { "type": "string", "format": "uri" },
    "sourceUrl": { "type": "string", "format": "uri" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "version": { "type": "string" },
    "license": { "type": "string" },
    "mcp": {
      "type": "object",
      "description": "Required when type == \"mcp\".",
      "properties": {
        "transport": { "type": "string", "enum": ["stdio", "http"], "default": "stdio" },
        "command": { "type": "string", "description": "Executable for stdio transport, e.g. npx." },
        "args": { "type": "array", "items": { "type": "string" } },
        "url": { "type": "string", "description": "Endpoint for http transport." },
        "serverType": { "type": "string", "description": "Protocol hint for http, e.g. sse or streamable-http." },
        "env": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key"],
            "properties": {
              "key": { "type": "string" },
              "description": { "type": "string" },
              "required": { "type": "boolean", "default": true },
              "secret": { "type": "boolean", "default": false },
              "default": { "type": "string" }
            }
          }
        }
      }
    },
    "source": {
      "type": "object",
      "description": "Required when type == \"skill\" or \"agent\".",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["bundled", "github"] },
        "repo": { "type": "string", "description": "owner/name (github source)." },
        "ref": { "type": "string", "default": "main" },
        "path": { "type": "string", "description": "File or directory path within the repo (github source)." },
        "isDirectory": { "type": "boolean", "default": false }
      }
    },
    "install": {
      "type": "object",
      "properties": {
        "dirName": { "type": "string", "description": "Skill directory name to install into, e.g. <tool>/skills/<dirName>/." },
        "fileName": { "type": "string", "description": "Agent file name to install as, e.g. <tool>/agents/<fileName>." }
      }
    },
    "items": {
      "type": "array",
      "description": "Required when type == \"bundle\". References other entry ids.",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      }
    }
  }
}
